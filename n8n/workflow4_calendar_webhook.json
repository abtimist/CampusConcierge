{
    "name": "Workflow 4: Calendar Webhook (Cloud Friendly)",
    "nodes": [
        {
            "parameters": {
                "path": "calendar-add",
                "responseMode": "responseNode",
                "options": {}
            },
            "id": "webhook-trigger",
            "name": "Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2,
            "position": [
                240,
                300
            ],
            "webhookId": "calendar-add"
        },
        {
            "parameters": {
                "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst deadline = new Date(body.opportunityDeadline);\nconst endDate = new Date(deadline);\nendDate.setDate(endDate.getDate() + 1);\n\nreturn [{\n  json: {\n    title: body.opportunityTitle,\n    description: `Apply: ${body.opportunityLink}`,\n    startDate: deadline.toISOString().split('T')[0],\n    endDate: endDate.toISOString().split('T')[0]\n  }\n}];"
            },
            "id": "prepare",
            "name": "Prepare Data",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                460,
                300
            ]
        },
        {
            "parameters": {
                "calendar": {
                    "mode": "id",
                    "value": "primary"
                },
                "start": "={{ $json.startDate }}",
                "end": "={{ $json.endDate }}",
                "additionalFields": {
                    "summary": "={{ $json.title }}",
                    "description": "={{ $json.description }}",
                    "allday": true
                }
            },
            "id": "create-event",
            "name": "Create Event",
            "type": "n8n-nodes-base.googleCalendar",
            "typeVersion": 1.3,
            "position": [
                700,
                300
            ],
            "credentials": {
                "googleCalendarOAuth2Api": {
                    "id": "gcal-creds",
                    "name": "Google Calendar"
                }
            }
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "{\"success\":true}",
                "options": {}
            },
            "id": "respond",
            "name": "Respond",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1,
            "position": [
                940,
                300
            ]
        }
    ],
    "connections": {
        "Webhook": {
            "main": [
                [
                    {
                        "node": "prepare",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "prepare": {
            "main": [
                [
                    {
                        "node": "create-event",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "create-event": {
            "main": [
                [
                    {
                        "node": "respond",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    }
}